    "outcomesModule": {
      "primaryOutcomes": [
        {
          "measure": "Safety and tolerability as determined by the number and severity of adverse events at the different dose levels",
          "timeFrame": "12 months"
        }
      ],
      "secondaryOutcomes": [
        {
          "measure": "To describe the single-dose PK and PD profiles (B-cell count) after a SBI-087 administration in subjects with RA",
          "timeFrame": "12 months"
        },
        {
          "measure": "To evaluate the effect of a pretreatment regimen on the occurrence of systemic reactions following SC administration of 100 mg or 200 mg SBI-087",
          "timeFrame": "12 month"
        },
        {
          "measure": "To investigate if changes in biomarkers (eg, complement activation markers, B-cells, CRP, IgE and tryptase levels) are related to the occurrence of systemic reactions on the day of infusion or injection of SBI-087",
          "timeFrame": "12 month"
        }
      ]
    },
    "eligibilityModule": {
      "eligibilityCriteria": "Inclusion Criteria:\n\n* Must meet American College of Rheumatology criteria for rheumatoid arthritis with functional class I to III.\n* Rheumatoid arthritis disease onset at \\>16 years of age and duration of disease at least 6 months.\n* Men or women of nonchildbearing potential (WONCBP), aged 20 to 70 years, inclusive at the screening visit.\n\nExclusion Criteria:\n\n* Any significant health problems other than rheumatoid arthritis.\n* Treatment of greater than 10 mg of prednisone per day.\n* Therapy with immunosuppressants within 6 months before study day 1",
      "healthyVolunteers": false,
